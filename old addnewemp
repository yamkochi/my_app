"use client"

import { useForm } from "react-hook-form"
import { addEmployeeAction } from "@/app/actions"

export default function AddEmployeeForm({ roles }) {
  const { register, handleSubmit } = useForm()

  const onSubmit = async (data) => {
    await addEmployeeAction(data)
  }

  return (
    <form
      onSubmit={handleSubmit(onSubmit)}
      className="space-y-4 bg-white p-6 rounded-lg shadow-md border"
    >
      <h2 className="text-xl font-bold mb-4">Add New Employee</h2>

      <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
        <section>
          <label className="block text-sm font-medium">Full Name</label>
          <input
            {...register("name", { required: true })}
            className="w-full border p-2 rounded"
            placeholder="John Doe"
          />
        </section>

        <section>
          <label className="block text-sm font-medium">Email Address</label>
          <input
            type="email"
            {...register("email", { required: true })}
            className="w-full border p-2 rounded"
          />
        </section>

        <section>
          <label className="block text-sm font-medium">Password</label>
          <input
            type="password"
            {...register("password", { required: true })}
            className="w-full border p-2 rounded"
          />
        </section>

        <section>
          <label className="block text-sm font-medium">Role</label>
          <select
            {...register("role_id")}
            className="w-full border p-2 rounded"
          >
            <option value="">Select a Role</option>
            {roles.map((role) => (
              <option key={role.id} value={role.id}>
                {role.role_name}
              </option>
            ))}
          </select>
        </section>
      </div>

      <section>
        <label className="block text-sm font-medium">Role Description</label>
        <textarea
          {...register("role_desc")}
          className="w-full border p-2 rounded"
          rows="2"
        />
      </section>

      <section>
        <label className="block text-sm font-medium">Photo URL</label>
        <input
          {...register("photo_url")}
          className="w-full border p-2 rounded"
          placeholder="https://image.path"
        />
      </section>

      <div className="grid grid-cols-2 gap-4">
        <section>
          <label className="block text-sm font-medium">Latitude</label>
          <input
            type="number"
            step="any"
            {...register("lat")}
            className="w-full border p-2 rounded"
          />
        </section>
        <section>
          <label className="block text-sm font-medium">Longitude</label>
          <input
            type="number"
            step="any"
            {...register("lng")}
            className="w-full border p-2 rounded"
          />
        </section>
      </div>

      <div className="grid grid-cols-2 gap-4">
        <section>
          <label className="block text-sm font-medium">Date Joined</label>
          <input
            type="date"
            {...register("date_joined")}
            className="w-full border p-2 rounded"
          />
        </section>
        <section>
          <label className="block text-sm font-medium">Log Time</label>
          <input
            type="datetime-local"
            {...register("logtime")}
            className="w-full border p-2 rounded"
          />
        </section>
      </div>

      <button
        type="submit"
        className="w-full bg-green-600 text-white py-2 rounded font-bold hover:bg-green-700 transition"
      >
        Create Employee Record
      </button>
    </form>
  )
}
